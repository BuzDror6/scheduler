generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_OWNER
  TEAM_MEMBER
  CLIENT
}

enum LocationType {
  PHONE_CALL
  GOOGLE_MEET
  ZOOM
  IN_PERSON
  CUSTOM
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
  PAYMENT_PENDING
  PAYMENT_FAILED
  REFUNDED
}

enum CalendarProvider {
  GOOGLE
  OUTLOOK
  APPLE
}

model User {
  id                     String               @id @default(cuid())
  fullName               String
  email                  String               @unique
  passwordHash           String
  phone                  String?
  businessName           String?
  profession             String?
  profileImageUrl        String?
  timezone               String               @default("Asia/Jerusalem")
  language               String               @default("he")
  bookingSlug            String               @unique
  websiteUrl             String?
  defaultLocationType    LocationType         @default(GOOGLE_MEET)
  defaultLocationDetails String?
  emailVerified          Boolean              @default(false)
  role                   UserRole             @default(BUSINESS_OWNER)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  eventTypes             EventType[]
  availabilityRules      AvailabilityRule[]
  blockedDates           BlockedDate[]
  bookings               Booking[]
  calendarConnections    CalendarConnection[]
  auditLogs              AuditLog[]

  @@map("users")
}

model EventType {
  id                    String      @id @default(cuid())
  userId                String
  title                 String
  description           String?
  durationMinutes       Int
  locationType          LocationType
  locationDetails       String?
  bufferBeforeMinutes   Int         @default(0)
  bufferAfterMinutes    Int         @default(0)
  minimumNoticeMinutes  Int         @default(60)
  maxDaysInAdvance      Int         @default(60)
  maxBookingsPerDay     Int?
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings              Booking[]

  @@index([userId, isActive])
  @@map("event_types")
}

model AvailabilityRule {
  id        String   @id @default(cuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
  @@map("availability_rules")
}

model BlockedDate {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  startTime String?
  endTime   String?
  isFullDay Boolean  @default(true)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("blocked_dates")
}

model Booking {
  id                    String        @id @default(cuid())
  userId                String
  eventTypeId           String
  clientName            String
  clientEmail           String
  clientPhone           String?
  clientNotes           String?
  startTime             DateTime
  endTime               DateTime
  timezone              String
  status                BookingStatus @default(CONFIRMED)
  cancellationToken     String        @unique
  rescheduleToken       String        @unique
  googleCalendarEventId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType             EventType     @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  emailLogs             EmailLog[]

  @@index([userId, startTime, endTime])
  @@index([eventTypeId, status])
  @@map("bookings")
}

model CalendarConnection {
  id                    String           @id @default(cuid())
  userId                String
  provider              CalendarProvider
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiry           DateTime?
  calendarId            String?
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("calendar_connections")
}

model EmailLog {
  id                String   @id @default(cuid())
  bookingId         String
  recipientEmail    String
  emailType         String
  status            String
  providerMessageId String?
  createdAt         DateTime @default(now())
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("email_logs")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("audit_logs")
}

